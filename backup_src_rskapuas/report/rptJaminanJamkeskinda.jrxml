	<queryString>
		<![CDATA[SELECT 
          jj.no_jaminan,
          jj.no_rawat,
          jj.no_kartu,
          reg_periksa.no_rkm_medis,
          pasien.nm_pasien,
          pasien.tgl_lahir,
          pasien.jk,
          pasien.no_tlp,
          jj.keterangan,
          jj.tgl_kunjungan,
          jj.status,
          jj.kd_dokter,
          jj.nm_dokter,
          jj.kd_poli,
          jj.nm_poli,
          jj.faskes_perujuk
        FROM jamkeskinda_jaminan jj
        INNER JOIN reg_periksa 
          ON jj.no_rawat = reg_periksa.no_rawat
        INNER JOIN pasien 
          ON reg_periksa.no_rkm_medis = pasien.no_rkm_medis
        WHERE jj.no_jaminan =  $P{nojaminan}]]>
	</queryString>
