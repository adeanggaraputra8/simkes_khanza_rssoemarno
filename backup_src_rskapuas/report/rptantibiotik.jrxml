	<queryString>
		<![CDATA[SELECT b.nm_bangsal, CONCAT(db.nama_brng,' ',db.kode_sat) Antibiotik, SUM(dpo.jml) jumlah
FROM detail_pemberian_obat dpo
INNER JOIN kamar_inap ki ON dpo.no_rawat=ki.no_rawat
INNER JOIN kamar k ON k.kd_kamar=ki.kd_kamar
INNER JOIN bangsal b on b.kd_bangsal=k.kd_bangsal
INNER JOIN databarang db ON db.kode_brng=dpo.kode_brng
WHERE dpo.tgl_perawatan BETWEEN '2019-01-01' AND '2019-01-31' AND db.kdjns='J012'
GROUP BY db.nama_brng, b.nm_bangsal
ORDER BY b.nm_bangsal ASC, db.nama_brng ASC]]>
	</queryString>
