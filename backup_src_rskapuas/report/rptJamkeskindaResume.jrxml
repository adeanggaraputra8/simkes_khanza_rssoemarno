	<queryString>
		<![CDATA[SELECT 
          jj.no_jaminan,
          jj.no_rawat,
          jj.no_kartu,
          reg_periksa.no_rkm_medis,
          pasien.nm_pasien,
          pasien.tgl_lahir,
          pasien.jk,
          pasien.no_tlp,
          jj.keterangan,
          jj.tgl_kunjungan,
          jj.status,
          jj.kd_dokter,
          jj.nm_dokter,
          jj.kd_poli,
          jj.nm_poli,
          jj.faskes_perujuk,
					pemeriksaan_ralan.suhu_tubuh,pemeriksaan_ralan.tensi,pemeriksaan_ralan.respirasi,pemeriksaan_ralan.nadi						,pemeriksaan_ralan.gcs,pemeriksaan_ralan.keluhan,pemeriksaan_ralan.pemeriksaan,pemeriksaan_ralan.alergi,pemeriksaan_ralan.kesadaran,pemeriksaan_ralan.berat,pemeriksaan_ralan.tinggi, CONCAT(diagnosa_pasien.kd_penyakit,' ',penyakit.nm_penyakit) as icd10,pemeriksaan_ralan.penilaian
        FROM jamkeskinda_jaminan jj
        INNER JOIN reg_periksa 
          ON jj.no_rawat = reg_periksa.no_rawat
				LEFT JOIN pemeriksaan_ralan ON pemeriksaan_ralan.no_rawat=reg_periksa.no_rawat
				INNER JOIN diagnosa_pasien ON diagnosa_pasien.no_rawat=reg_periksa.no_rawat
         INNER JOIN penyakit ON penyakit.kd_penyakit=diagnosa_pasien.kd_penyakit 
        INNER JOIN pasien 
          ON reg_periksa.no_rkm_medis = pasien.no_rkm_medis
        WHERE jj.no_jaminan =  $P{nojaminan}  GROUP BY penyakit.kd_penyakit ORDER BY diagnosa_pasien.prioritas ASC,pemeriksaan_ralan.jam_rawat DESC;]]>
	</queryString>
