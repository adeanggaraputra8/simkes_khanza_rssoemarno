	<queryString>
		<![CDATA[select reg_periksa.no_reg,bridging_sep.no_sep, bridging_sep.no_rawat,bridging_sep.nomr,bridging_sep.nama_pasien,bridging_sep.tglsep,
bridging_sep.tglrujukan,bridging_sep.no_rujukan,bridging_sep.kdppkrujukan,
bridging_sep.nmppkrujukan,bridging_sep.kdppkpelayanan,bridging_sep.nmppkpelayanan,
if(bridging_sep.jnspelayanan='1','Rawat Inap','Rawat Jalan'),bridging_sep.catatan,bridging_sep.diagawal,
bridging_sep.nmdiagnosaawal,bridging_sep.kdpolitujuan,bridging_sep.nmpolitujuan,
if(bridging_sep.klsrawat='1','Kelas 1',if(bridging_sep.klsrawat='2','Kelas 2','Kelas 3')),
if(bridging_sep.lakalantas='0','Kasus Kecelakaan','Bukan Kasus Kecelakaan'),bridging_sep.user, 
bridging_sep.tanggal_lahir,bridging_sep.peserta,bridging_sep.jkel,bridging_sep.no_kartu,
bridging_sep.asal_rujukan,bridging_sep.eksekutif,bridging_sep.cob,bridging_sep.notelep,dokter.nm_dokter,
if(bridging_sep.tujuankunjungan='0',' Konsul Dokter (Pertama)',if(bridging_sep.tujuankunjungan='1','Prosedur','Konsul')) as tujkunj,if(bridging_sep.asesmenpelayanan='1',' Poli spesialis tidak tersedia',if(bridging_sep.asesmenpelayanan='2','jam Poli telah berakhir',if(bridging_sep.asesmenpelayanan='3','Spesialis yang dimaksud tidak praktek',if(bridging_sep.asesmenpelayanan='4','Atas Instruksi RS',if(bridging_sep.asesmenpelayanan='5','Tujuan Kontrol',' '))))) as asesmen,
 CONCAT(diagnosa_pasien.kd_penyakit,' ',penyakit.nm_penyakit) as icd10
from bridging_sep
INNER JOIN reg_periksa ON bridging_sep.no_rawat = reg_periksa.no_rawat
INNER JOIN dokter  ON dokter.kd_dokter = reg_periksa.kd_dokter 
						INNER JOIN diagnosa_pasien ON diagnosa_pasien.no_rawat=reg_periksa.no_rawat
						INNER JOIN penyakit ON penyakit.kd_penyakit=diagnosa_pasien.kd_penyakit
WHERE reg_periksa.kd_dokter NOT IN ( '-' ) and bridging_sep.kdpolitujuan NOT IN ('IRM') and bridging_sep.no_rawat=$P{norawat}  GROUP BY penyakit.kd_penyakit ORDER BY diagnosa_pasien.prioritas ASC;]]>
	</queryString>
